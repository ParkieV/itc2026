{
  "compilerOptions": {
    "lib": ["ES2023", "DOM"],
    "outDir": "./dist",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["components/*"],
      "@pages/*": ["pages/*"],
      "@assets/*": ["assets/*"],
      "@ui/*": ["ui/*"],
      "@store/*": ["store/*"],
      "@api/*": ["store/api/*"],
      "@hooks/*": ["hooks/*"],
      "@styles/*": ["shared/styles/*"],
      "@translations/*": ["data/*"],
      "@types/*": ["shared/types/*"],
      "@utils/*": ["shared/utils/*"],
      "@mocks/*": ["mocks/*"],
      "@shared/*": ["shared/*"],
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
  },
  "include": ["src","types"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
